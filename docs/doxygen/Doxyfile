# Doxyfile for PDFDocumentView (standalone; no CMake required).
# Run from this directory:  doxygen Doxyfile
# HTML output: ./html/index.html
# Prerequisite: install Doxygen (https://www.doxygen.nl).
# Keep PROJECT_NUMBER loosely aligned with root CMakeLists.txt project() VERSION.

PROJECT_NAME           = PDFDocumentView
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "Embeddable Qt PDF page widget (public API under include/pdf_document_view/)."

OUTPUT_DIRECTORY       = html
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = NO

INPUT                  = ../../include
FILE_PATTERNS          = *.hpp
RECURSIVE              = YES
EXCLUDE_SYMLINKS       = YES

EXTENSION_MAPPING      = hpp=C++

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = .
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

HTML_COLORSTYLE_HUE    = 220

SHOW_INCLUDE_FILES     = YES
SHOW_USED_FILES        = YES

SOURCE_BROWSER         = NO
REFERENCED_BY_RELATION = NO
REFERENCES_RELATION    = NO

CLASS_GRAPH            = NO
